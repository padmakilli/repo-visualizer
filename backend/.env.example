# ---------------------------------------------------------------------------
# AI provider configuration
# ---------------------------------------------------------------------------
# Which provider to use for file explanations: "anthropic", "openai",
# "gemini", or "none" (disables AI; the rest of the app still works).
AI_PROVIDER=anthropic

# Supply the key for whichever provider you selected above.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Model overrides (sensible, cost-efficient defaults are used if left blank).
ANTHROPIC_MODEL=claude-haiku-4-5
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-flash

# ---------------------------------------------------------------------------
# Analysis configuration
# ---------------------------------------------------------------------------
# Optional hard sandbox. If set, only paths under this directory may be
# analyzed or explained. Leave blank to allow any readable directory (the
# server still confines per-file reads to whatever roots you analyze).
REPO_ROOT=

# Files larger than this (bytes) are listed but not read for content/metrics.
MAX_FILE_BYTES=1000000

# SQLite cache for AI summaries (keyed by file content hash).
CACHE_DB=./.cache/summaries.db

# CORS origins for the frontend dev server.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
